# 📦 Dependency Directories
# هرگز node_modules را آپلود نکن چون بسیار سنگین است و با npm install دوباره ساخته می‌شود
node_modules/

# 🛠️ Build & Environment
# اگر فایلی برای تنظیمات شخصی داری
.env
.DS_Store
Thumbs.db

# 🧪 Logs
# فایل‌های گزارش خطا که توسط npm ساخته می‌شوند
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 📂 IDE / Editor
# تنظیمات شخصی ادیتورها مثل VS Code
.vscode/
.idea/
*.swp